{
  "name": "@eamilos/cli",
  "version": "1.0.0",
  "description": "EamilOS CLI — AI Execution Kernel",
  "type": "module",
  "main": "dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "eamilos": "./bin/eamilos"
  },
  "files": [
    "dist/**/*",
    "bin/eamilos",
