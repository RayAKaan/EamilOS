{
  "name": "@eamilos/core",
  "version": "1.2.7",
  "description": "EamilOS core library — AI execution kernel for validated, working code",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RayAKaan/EamilOS.git"
  },
  "keywords": [
    "ai",
    "cli",
    "agents",
    "automation",
    "ollama",
    "llm",
    "developer-tools"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "acorn": "^8.16.0",
    "better-sqlite3": "^11.8.0",
    "chalk": "^5.4.0",
    "nanoid": "^5.1.0",
    "node-pty": "^1.0.0",
    "ora": "^8.2.0",
    "simple-git": "^3.27.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.2",
    "rimraf": "^5.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
