{
  "name": "eamilos",
  "version": "1.2.3",
  "description": "Agentic Operating Ground - Multi-agent coordination platform",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
"scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "clean": "npm run clean --workspaces --if-present",
    "reset": "rm -rf node_modules packages/*/node_modules packages/*/dist",
    "ui": "npm run start -w @eamilos/cli-ui",
    "cli": "npx eamilos"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "agent",
    "ai",
    "multi-agent",
    "orchestration",
    "coordination"
  ],
  "author": "",
  "license": "MIT"
}
